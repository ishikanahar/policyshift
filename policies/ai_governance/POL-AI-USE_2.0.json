  ],
  "required_evidence": [
    "model_id",
    "approved_model_registry",
    "data_classification",
    "tool_access_grant"
  ],
  "permitted_actions": [
    "inspect_case",
    "inspect_evidence",
    "retrieve_policy",
    "search_policy_clauses",
    "create_human_review",
    "report_ai_incident",
    "finalize_case"
  ],
