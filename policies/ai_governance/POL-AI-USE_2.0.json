{
  "schema_version": "1.0.0",
  "policy_id": "POL-AI-USE",
  "domain": "ai_governance",
  "version": "2.0",
  "title": "Synthetic Enterprise Data and AI Use Policy",
  "effective_at": "2025-01-01T00:00:00Z",
  "expires_at": null,
  "supersedes": "1.1",
  "scope": "Internal AI tool use for research and operations in Org Synthetic.",
  "definitions": {
    "sensitive_data": "Data classified as confidential or higher in the synthetic taxonomy.",
    "approved_model": "Model id listed on the synthetic approved-model registry."
  },
  "clauses": [
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-SENS",
      "text": "Sensitive or confidential data must not be sent to external APIs.",
      "rule_type": "prohibition",
      "conditions": [
        "contains_sensitive==true",
        "external_api==true"
      ],
      "required_fields": [],
      "expected_action": "report_ai_incident",
      "severity": "critical",
      "exception_ids": [],
      "tags": [
        "sensitive",
        "modified"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-PUBLIC-API",
      "text": "External APIs may be used for public metadata that is not sensitive.",
      "rule_type": "permission",
      "conditions": [
        "contains_sensitive==false",
        "data_classification==public"
      ],
      "required_fields": [],
      "expected_action": null,
      "severity": "low",
      "exception_ids": [],
      "tags": [
        "external_api",
        "relaxed"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-MODEL",
      "text": "Only approved models may be used for production workflows.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "model_id",
        "approved_model_registry"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "approved_model",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-TOOLS",
      "text": "Agents may invoke only tools listed on the user tool-access grant.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "tool_access_grant"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "tool_access",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-HUMAN",
      "text": "High-impact actions require human approval before execution.",
      "rule_type": "escalation",
      "conditions": [
        "high_impact==true"
      ],
      "required_fields": [],
      "expected_action": "create_human_review",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "human_approval",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-VERIFY",
      "text": "Model outputs used for operational decisions must be verified against source records.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "verification_record"
      ],
      "expected_action": "inspect_evidence",
      "severity": "medium",
      "exception_ids": [],
      "tags": [
        "verification",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-RETAIN",
      "text": "Prompt and output logs for sensitive workflows are retained for 60 days.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "retention_days"
      ],
      "expected_action": null,
      "severity": "low",
      "exception_ids": [],
      "tags": [
        "retention",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-NO-REDACT-EX",
      "text": "Redacted confidential excerpts are not exempt from external-API prohibition.",
      "rule_type": "prohibition",
      "conditions": [],
      "required_fields": [],
      "expected_action": null,
      "severity": "critical",
      "exception_ids": [],
      "tags": [
        "sensitive",
        "removed_exception"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-2.0-INCIDENT",
      "text": "Suspected policy violations must be reported as AI incidents.",
      "rule_type": "escalation",
      "conditions": [],
      "required_fields": [],
      "expected_action": "report_ai_incident",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "incident",
        "unchanged"
      ]
