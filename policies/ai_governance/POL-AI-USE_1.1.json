{
  "schema_version": "1.0.0",
  "policy_id": "POL-AI-USE",
  "domain": "ai_governance",
  "version": "1.1",
  "title": "Synthetic Enterprise Data and AI Use Policy",
  "effective_at": "2024-07-01T00:00:00Z",
  "expires_at": "2025-01-01T00:00:00Z",
  "supersedes": "1.0",
  "scope": "Internal AI tool use for research and operations in Org Synthetic.",
  "definitions": {
    "sensitive_data": "Data classified as confidential or higher in the synthetic taxonomy.",
    "approved_model": "Model id listed on the synthetic approved-model registry."
  },
  "clauses": [
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-SENS",
      "text": "Sensitive data must not be sent to external APIs.",
      "rule_type": "prohibition",
      "conditions": [
        "contains_sensitive==true",
        "external_api==true"
      ],
      "required_fields": [],
      "expected_action": "report_ai_incident",
      "severity": "critical",
      "exception_ids": [],
      "tags": [
        "sensitive",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-MODEL",
      "text": "Only approved models may be used for production workflows.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "model_id",
        "approved_model_registry"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "approved_model",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-TOOLS",
      "text": "Agents may invoke only tools listed on the user tool-access grant.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "tool_access_grant"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "tool_access",
        "new"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-HUMAN",
      "text": "High-impact actions require human approval before execution.",
      "rule_type": "escalation",
      "conditions": [
        "high_impact==true"
      ],
      "required_fields": [],
      "expected_action": "create_human_review",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "human_approval",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-VERIFY",
      "text": "Model outputs used for operational decisions must be verified against source records.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "verification_record"
      ],
      "expected_action": "inspect_evidence",
      "severity": "medium",
      "exception_ids": [],
      "tags": [
        "verification",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-RETAIN",
      "text": "Prompt and output logs for sensitive workflows are retained for 60 days.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "retention_days"
      ],
      "expected_action": null,
      "severity": "low",
      "exception_ids": [],
      "tags": [
        "retention",
        "stricter"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "AI-1.1-INCIDENT",
      "text": "Suspected policy violations must be reported as AI incidents.",
      "rule_type": "escalation",
      "conditions": [],
      "required_fields": [],
      "expected_action": "report_ai_incident",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "incident",
        "unchanged"
      ]
    }
  ],
  "required_evidence": [
    "model_id",
    "approved_model_registry",
    "data_classification",
    "tool_access_grant"
  ],
  "permitted_actions": [
    "inspect_case",
    "inspect_evidence",
    "retrieve_policy",
    "search_policy_clauses",
    "create_human_review",
    "report_ai_incident",
    "finalize_case"
  ],
  "prohibited_actions": [
    "alter_evidence",
    "release_item",
    "approve_equipment_access"
  ],
  "exceptions": [
    {
      "schema_version": "1.0.0",
      "exception_id": "AI-EX-REDACTED",
      "text": "Redacted excerpts of sensitive data may be used with local approved models only.",
      "conditions": [
        "redacted==true",
        "external_api==false",
        "approved_model==true"
      ],
      "requires_approval": false
    }
  ],
  "escalation_conditions": [
    "high_impact==true",
    "unapproved_model==true",
    "external_sensitive==true"
  ],
  "examples": [
    "Local approved model on non-sensitive data may proceed.",
    "External API with sensitive payload must be blocked and reported."
  ],
  "change_summary": "Tool-access permissions required; retention extended to 60 days; redaction exception retained.",
  "change_log": [
    "2024-07-01: Explicit tool-access permission check added.",
    "2024-07-01: Retention window increased from 30 to 60 days.",
    "2024-07-01: External sensitive-data prohibition unchanged."
  ],
