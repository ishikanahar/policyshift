  "supersedes": "1.0",
  "scope": "Inbound biological and chemical research materials at Facility North.",
  "definitions": {
    "temperature_sensitive": "Material requiring continuous cold-chain control.",
    "quarantine": "Hold status preventing release into inventory.",
    "coa": "Certificate of analysis from the supplier."
  },
  "clauses": [
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-TEMP",
      "text": "Temperature-sensitive materials must arrive with a continuous temperature log.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "temperature_log"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "temperature",
        "evidence",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-COA",
      "text": "A valid certificate of analysis issued within 90 days is required before release.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "coa",
        "coa_issue_date"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "coa",
        "evidence",
        "stricter"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-DAMAGE",
      "text": "Damaged packaging requires quarantine and human review.",
      "rule_type": "escalation",
      "conditions": [
        "packaging_damaged==true"
      ],
      "required_fields": [],
      "expected_action": "quarantine_item",
      "severity": "critical",
      "exception_ids": [],
      "tags": [
        "damage",
        "quarantine",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-LOT",
      "text": "Lot number on the shipment must match the purchase order.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "lot_number",
        "purchase_order"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "lot",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-RELEASE",
      "text": "Release is permitted only when all required evidence is present and undamaged.",
      "rule_type": "permission",
      "conditions": [],
      "required_fields": [],
      "expected_action": "release_item",
      "severity": "medium",
      "exception_ids": [],
      "tags": [
        "release"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-PROHIBIT-RELEASE-MISSING",
      "text": "Do not release materials with missing or stale COA or missing temperature log.",
      "rule_type": "prohibition",
      "conditions": [],
      "required_fields": [],
      "expected_action": null,
      "severity": "critical",
      "exception_ids": [],
      "tags": [
        "release",
        "prohibited",
        "stricter"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-QTY",
      "text": "Quantity mismatches of more than 5% require quarantine.",
      "rule_type": "escalation",
      "conditions": [
        "quantity_mismatch_pct>5"
      ],
      "required_fields": [],
      "expected_action": "quarantine_item",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "quantity",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "MAT-1.1-DUAL",
      "text": "Dual-sourced lots may be accepted with supervisor approval and matched COAs.",
      "rule_type": "exception",
      "conditions": [],
      "required_fields": [],
      "expected_action": "create_human_review",
      "severity": "medium",
      "exception_ids": [
        "MAT-EX-DUAL"
      ],
      "tags": [
        "exception",
        "new"
      ]
    }
  ],
  "required_evidence": [
    "temperature_log",
    "coa",
    "coa_issue_date",
    "lot_number",
    "purchase_order"
  ],
  "permitted_actions": [
    "inspect_case",
    "inspect_evidence",
    "retrieve_policy",
    "search_policy_clauses",
    "request_missing_evidence",
    "quarantine_item",
    "release_item",
    "create_human_review",
    "finalize_case"
  ],
  "prohibited_actions": [
    "alter_evidence",
    "approve_equipment_access"
  ],
  "exceptions": [
    {
      "schema_version": "1.0.0",
      "exception_id": "MAT-EX-DUAL",
      "text": "Dual-sourced lots require supervisor approval and two matching COAs.",
      "conditions": [
        "dual_sourced==true",
        "supervisor_approval==true"
      ],
      "requires_approval": true
    }
  ],
  "escalation_conditions": [
    "packaging_damaged==true",
    "quantity_mismatch_pct>5",
    "coa_expired==true"
  ],
  "examples": [
    "Intact cold-chain shipment with matching lot and valid COA may be released.",
    "Torn packaging must be quarantined even if COA is valid."
  ],
  "change_summary": "Stricter COA freshness; temporary exception for dual-sourced lots; quantity threshold unchanged.",
