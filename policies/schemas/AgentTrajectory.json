{
  "$defs": {
    "AgentAction": {
      "description": "Observable agent step with a short structured decision summary (no hidden CoT).",
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "description": "PolicyShift data schema version",
          "title": "Schema Version",
          "type": "string"
        },
        "step_number": {
          "title": "Step Number",
          "type": "integer"
        },
        "thought_summary": {
          "description": "Short structured rationale summary; not unrestricted chain-of-thought.",
          "title": "Thought Summary",
          "type": "string"
        },
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        },
        "arguments": {
          "additionalProperties": true,
          "title": "Arguments",
          "type": "object"
        },
        "tool_output": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Output"
        },
        "policy_citations": {
          "items": {
            "type": "string"
          },
          "title": "Policy Citations",
          "type": "array"
        },
        "timestamp": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "required": [
        "step_number",
        "thought_summary",
        "tool_name"
      ],
      "title": "AgentAction",
      "type": "object"
    },
    "FailureCategory": {
      "enum": [
        "stale_policy_selected",
        "correct_policy_retrieved_but_ignored",
        "incorrect_clause_selected",
        "missing_evidence_overlooked",
        "invalid_tool",
        "invalid_tool_arguments",
        "unsupported_final_answer",
        "hallucinated_evidence",
        "hallucinated_policy",
        "premature_action",
        "unsafe_action",
        "unnecessary_escalation",
        "excessive_refusal",
        "excessive_tool_use",
        "reward_hacking",
        "correct_result_through_invalid_reasoning_path",
        "retrieval_failure",
        "version_boundary_confusion",
        "exception_handling_failure"
      ],
      "title": "FailureCategory",
      "type": "string"
    },
    "RewardBreakdown": {
      "description": "Decomposable reward components for a trajectory.",
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "description": "PolicyShift data schema version",
          "title": "Schema Version",
          "type": "string"
        },
        "components": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Components",
          "type": "object"
        },
        "total": {
          "default": 0.0,
          "title": "Total",
          "type": "number"
        },
        "config_name": {
          "default": "balanced_full",
          "title": "Config Name",
          "type": "string"
        }
      },
      "title": "RewardBreakdown",
      "type": "object"
    },
    "TrainingMethod": {
      "enum": [
        "base",
        "rag",
        "sft_sequential",
        "sft_replay",
        "distillation",
        "dpo",
        "rl",
        "oracle",
        "demo"
      ],
      "title": "TrainingMethod",
      "type": "string"
    },
    "VerifierResult": {
      "description": "Single deterministic verifier check result.",
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "description": "PolicyShift data schema version",
          "title": "Schema Version",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "detail": {
          "default": "",
          "title": "Detail",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "required": [
        "name",
        "passed"
      ],
      "title": "VerifierResult",
      "type": "object"
    }
  },
  "description": "Full observed agent trajectory for a case.",
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "description": "PolicyShift data schema version",
      "title": "Schema Version",
      "type": "string"
    },
    "trajectory_id": {
      "title": "Trajectory Id",
      "type": "string"
    },
    "case_id": {
      "title": "Case Id",
      "type": "string"
    },
    "model_id": {
      "title": "Model Id",
      "type": "string"
    },
    "training_method": {
      "$ref": "#/$defs/TrainingMethod"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/AgentAction"
      },
      "title": "Actions",
      "type": "array"
    },
    "final_answer": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Final Answer"
    },
    "cited_policy_versions": {
      "items": {
        "type": "string"
      },
      "title": "Cited Policy Versions",
      "type": "array"
    },
    "reward_components": {
      "$ref": "#/$defs/RewardBreakdown"
    },
    "total_reward": {
      "default": 0.0,
      "title": "Total Reward",
      "type": "number"
    },
    "verifier_results": {
      "items": {
        "$ref": "#/$defs/VerifierResult"
      },
      "title": "Verifier Results",
      "type": "array"
    },
    "failure_categories": {
      "items": {
        "$ref": "#/$defs/FailureCategory"
      },
      "title": "Failure Categories",
      "type": "array"
    },
    "latency_ms": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Latency Ms"
    },
    "token_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Token Count"
    },
    "success": {
      "default": false,
      "title": "Success",
      "type": "boolean"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    }
  },
  "required": [
    "trajectory_id",
    "case_id",
    "model_id",
    "training_method"
  ],
  "title": "AgentTrajectory",
  "type": "object"
}
