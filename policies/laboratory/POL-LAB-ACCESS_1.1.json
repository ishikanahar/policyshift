      "schema_version": "1.0.0",
      "clause_id": "LAB-1.1-APPROVE",
      "text": "Approve access only when training, calibration, reservation, and access-level checks pass.",
      "rule_type": "permission",
      "conditions": [],
      "required_fields": [],
      "expected_action": "approve_equipment_access",
      "severity": "medium",
      "exception_ids": [],
      "tags": [
        "approve",
        "modified"
      ]
