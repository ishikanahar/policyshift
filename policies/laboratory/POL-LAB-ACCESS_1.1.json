      "conditions": [],
      "required_fields": [
        "calibration_certificate"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "calibration",
        "unchanged"
      ]
    },
    {
