  "required_evidence": [
    "training_record",
    "calibration_certificate",
    "reservation",
    "access_level"
  ],
  "permitted_actions": [
    "inspect_case",
    "inspect_evidence",
    "retrieve_policy",
    "search_policy_clauses",
    "approve_equipment_access",
    "deny_equipment_access",
    "create_human_review",
    "finalize_case"
  ],
  "prohibited_actions": [
