        "training",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-CAL",
      "text": "Instrument calibration must be valid at the reservation time.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "calibration_certificate"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "calibration",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-RESERVE",
      "text": "A confirmed reservation is required for scheduled instrument use.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "reservation"
      ],
      "expected_action": "inspect_evidence",
      "severity": "medium",
      "exception_ids": [],
      "tags": [
        "reservation",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-LEVEL",
      "text": "User access level must meet or exceed the instrument minimum access level.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "access_level",
        "instrument_min_level"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "access_level",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-AFTER",
      "text": "After-hours use requires supervisor approval unless user access level is 3 or higher and an auto-audit log entry is created.",
      "rule_type": "exception",
      "conditions": [
        "after_hours==true"
      ],
      "required_fields": [],
      "expected_action": "approve_equipment_access",
      "severity": "medium",
      "exception_ids": [
        "LAB-EX-AFTER-L3"
      ],
      "tags": [
        "after_hours",
        "relaxed"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-QC-FAIL",
      "text": "Failed quality-control checks deny equipment access.",
      "rule_type": "prohibition",
      "conditions": [
        "qc_failed==true"
      ],
      "required_fields": [],
      "expected_action": "deny_equipment_access",
      "severity": "critical",
      "exception_ids": [],
      "tags": [
        "qc",
        "unchanged"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-NO-MAINT-BYPASS",
      "text": "Maintenance personnel must follow the same access checks outside declared outages.",
      "rule_type": "prohibition",
      "conditions": [],
      "required_fields": [],
      "expected_action": null,
      "severity": "high",
      "exception_ids": [],
      "tags": [
        "maintenance",
        "removed_exception"
      ]
    },
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-APPROVE",
      "text": "Approve access only when all applicable checks pass under the active version.",
      "rule_type": "permission",
      "conditions": [],
      "required_fields": [],
      "expected_action": "approve_equipment_access",
      "severity": "medium",
      "exception_ids": [],
      "tags": [
        "approve"
      ]
