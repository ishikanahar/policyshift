    "release_item"
  ],
  "exceptions": [
    {
      "schema_version": "1.0.0",
      "exception_id": "LAB-EX-AFTER-L3",
      "text": "Access level >= 3 may use after hours with auto-audit logging.",
      "conditions": [
        "access_level>=3",
        "after_hours==true",
        "auto_audit==true"
      ],
      "requires_approval": false
