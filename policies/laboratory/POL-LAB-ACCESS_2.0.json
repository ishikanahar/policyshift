  "clauses": [
    {
      "schema_version": "1.0.0",
      "clause_id": "LAB-2.0-TRAIN",
      "text": "Users must hold current instrument-specific training before access.",
      "rule_type": "requirement",
      "conditions": [],
      "required_fields": [
        "training_record"
      ],
      "expected_action": "inspect_evidence",
      "severity": "high",
      "exception_ids": [],
