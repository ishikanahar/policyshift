# PolicyShift environment variables (never commit real secrets)

# Optional retrieval APIs (Phase 2+) — local Sentence Transformers works without these
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-english-v3.0
COHERE_RERANK_MODEL=rerank-english-v3.0

# Optional teacher API (Phase 3+) — smoke tests use pre-generated trajectories
TEACHER_API_BASE=
TEACHER_API_KEY=
TEACHER_MODEL=

# Optional student serving (Phase 8 live mode)
STUDENT_MODEL_PATH=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Paths
POLICYSHIFT_DATA_DIR=data
POLICYSHIFT_ARTIFACT_DIR=artifacts
POLICYSHIFT_SEED=42
